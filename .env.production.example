# SignalBox production environment example.
# Copy to .env.production and replace every secret before deployment.

SIGNALBOX_VERSION=v1.0.0
SIGNALBOX_HOST_PORT=8080

POSTGRES_DB=signalbox
POSTGRES_USER=signalbox
POSTGRES_PASSWORD=change-me-use-a-long-random-password

# Use at least 32-64 random characters.
ADMIN_API_KEY=change-me-use-a-long-random-admin-key

# For a first VPS deployment AUTO_MIGRATE=true is acceptable.
# For stricter production, manage migrations separately and set AUTO_MIGRATE=false.
AUTO_MIGRATE=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

MAX_BODY_BYTES=1048576
WEBHOOK_RATE_LIMIT_REQUESTS=120
WEBHOOK_RATE_LIMIT_WINDOW=1m

DELIVERY_WORKER_ENABLED=true
DELIVERY_WORKER_INTERVAL=5s
DELIVERY_WORKER_BATCH_SIZE=10
DELIVERY_WORKER_LOCK_DURATION=1m
DELIVERY_MAX_ATTEMPTS=8
